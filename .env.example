# claude-session-budget — sample .env
# Copy to ./.env (per-project) or ~/.claude/.env (global). Process env vars win.

# Threshold to start logging "sync" warnings (percent, 1-100). Default: 80
BUDGET_SYNC_PCT=80

# Threshold to BLOCK new tool calls / pause dispatch (percent, 1-100). Default: 93
BUDGET_PAUSE_PCT=93

# Pause behavior once usage reaches BUDGET_PAUSE_PCT.
# block = immediately block the tool call (default, safest)
# sleep = keep the hook process alive, re-check periodically, then allow the
#         original tool call to continue if usage falls below the pause threshold
BUDGET_PAUSE_MODE=block

# Sleep-mode tuning. These are ignored unless BUDGET_PAUSE_MODE=sleep.
BUDGET_RECHECK_SECS=60
# After usage drops below the pause threshold, sleep this many seconds and
# re-check once before allowing the original tool call to continue.
BUDGET_RESET_GRACE_SECS=60
BUDGET_MAX_SLEEP_SECS=14400

# Override the auto-learned calibration limit (weighted tokens). Leave unset
# to use the value in ~/.claude/.budget_calibration.json (auto-updated).
# BUDGET_CALIBRATED_LIMIT=63226913

# EWMA smoothing factor for auto-calibration (0-1). Higher = trust new
# observations more. Default: 0.3
BUDGET_EWMA_ALPHA=0.3

# Override scan locations (advanced).
# BUDGET_PROJECTS_DIR=~/.claude/projects
# BUDGET_CALIBRATION_FILE=~/.claude/.budget_calibration.json
